---
import Base from '../layouts/Base.astro';
---

<Base title="Gallery — Opinionated Imagen">
  <main class="mx-auto max-w-5xl px-6 py-20">
    <h1 class="text-3xl font-semibold tracking-tight">Your gallery</h1>
    <p class="mt-2 text-muted-foreground">Saved shots from your contact sheets.</p>

    <div id="gallery-app" class="mt-10"></div>
  </main>

  <script>
    import { mountGallery } from '../islands/gallery-app';
    const el = document.getElementById('gallery-app');
    if (el) mountGallery(el);
  </script>
</Base>
