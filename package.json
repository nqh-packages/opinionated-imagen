{
  "name": "opinionated-imagen",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm:dev:astro\" \"pnpm:dev:api\" --names 'astro,api' --prefix-colors cyan,yellow",
    "dev:astro": "astro dev",
    "dev:api": "wrangler dev functions/index.ts --compatibility-date=2025-04-01 --port=8787",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p functions/tsconfig.json"
  },
  "dependencies": {
    "@arrow-js/core": "^1.0.0",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/noto-serif": "^5.2.9",
    "@fontsource-variable/roboto-slab": "^5.2.8",
    "@tabler/icons-react": "^3.43.0",
    "astro": "^6.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.4",
    "@cloudflare/workers-types": "^4.20250401.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "wrangler": "^4.10.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
