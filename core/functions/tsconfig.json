{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "baseUrl": "."
  },
  "include": ["index.ts", "routes/**/*.ts", "middleware/**/*.ts", "lib/**/*.ts", "generated/**/*.ts"],
  "exclude": ["node_modules", "**/__tests__/**", "scripts/**"]
}
