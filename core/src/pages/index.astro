---
import Base from '../layouts/Base.astro';
---

<Base title="Opinionated Imagen">
  <main class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <h1 class="text-4xl font-semibold tracking-tight sm:text-6xl">
      Photos that look like <span class="italic">you</span> took them
    </h1>
    <p class="mt-6 max-w-lg text-lg text-muted-foreground">
      Upload your selfies. Pick a vibe. Get a contact sheet of variations.
      No prompt engineering. No surprises.
    </p>
    <div class="mt-10 flex gap-4">
      <a
        href="/onboard"
        class="inline-flex h-11 items-center justify-center rounded-md bg-primary px-8 text-sm font-medium text-primary-foreground hover:bg-primary/90"
      >
        Get started
      </a>
      <a
        href="/create"
        class="inline-flex h-11 items-center justify-center rounded-md border border-border bg-background px-8 text-sm font-medium hover:bg-accent hover:text-accent-foreground"
      >
        Create
      </a>
    </div>
  </main>
</Base>
