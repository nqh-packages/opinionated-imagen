---
import Base from '../../layouts/Base.astro';

const token = Astro.url.searchParams.get('token');
---

<Base title="Signing in — Opinionated Imagen">
  <main class="mx-auto flex min-h-[60vh] max-w-md flex-col items-center justify-center px-6 py-20 text-center">
    <h1 class="text-2xl font-semibold tracking-tight">Opinionated Imagen</h1>

    <div id="verify-status" class="mt-8">
      <p class="text-muted-foreground">Signing you in…</p>
    </div>
  </main>

  <script>
    (async function () {
      const statusEl = document.getElementById('verify-status');
      const token = new URLSearchParams(window.location.search).get('token');

      if (!token) {
        if (statusEl) {
          statusEl.innerHTML =
            '<p class="text-destructive">Missing verification link. Check the link you clicked.</p>';
        }
        return;
      }

      try {
        const res = await fetch(`/api/auth/verify?token=${encodeURIComponent(token)}`);
        const data = await res.json();

        if (data.ok && data.redirectTo) {
          // First, wait briefly so the cookie is set by the browser
          await new Promise(r => setTimeout(r, 100));
          window.location.href = data.redirectTo;
        } else {
          if (statusEl) {
            statusEl.innerHTML =
              '<div class="space-y-4"><p class="text-destructive">' +
              (data.error || 'This link has expired or is invalid.') +
              '</p><p class="text-sm text-muted-foreground">Request a new sign-in link.</p></div>';
          }
        }
      } catch {
        if (statusEl) {
          statusEl.innerHTML =
            '<p class="text-destructive">Something went wrong. Try again.</p>';
        }
      }
    })();
  </script>
</Base>
