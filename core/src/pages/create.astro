---
import Base from '../layouts/Base.astro';
import CreateApp from '../islands/CreateApp';
---

<Base title="Create — Opinionated Imagen">
  <main class="mx-auto max-w-2xl px-6 py-20">
    <h1 class="text-3xl font-semibold tracking-tight">Choose a Scene</h1>
    <p class="mt-2 text-muted-foreground">
      Browse curated Scenes and explore each Brief before confirming.
    </p>

    <div class="mt-10">
      <CreateApp client:load />
    </div>
  </main>
</Base>
